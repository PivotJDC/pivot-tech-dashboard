# Copy to .env.local for local dev. The browser calls this base URL directly;
# it must be a public, non-secret value (NEXT_PUBLIC_* is inlined into the
# client bundle). Set the same value in Netlify (or rely on netlify.toml).
NEXT_PUBLIC_API_URL=https://bwgwcrstym.us-east-1.awsapprunner.com

# Admin (/admin) MVP password gate. WARNING: NEXT_PUBLIC_* is inlined into the
# client bundle, so this is NOT secret — it gates a convenience UI, not data.
# Its value is also sent as the Bearer credential to the middleware admin API,
# so set it to a credential the middleware's adminAuth accepts (an admin JWT).
NEXT_PUBLIC_ADMIN_TOKEN=
