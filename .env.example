# Copy to .env.local for local dev. The browser calls this base URL directly;
# it must be a public, non-secret value (NEXT_PUBLIC_* is inlined into the
# client bundle). Set the same value in Netlify (or rely on netlify.toml).
NEXT_PUBLIC_API_URL=https://bwgwcrstym.us-east-1.awsapprunner.com

# The /admin console has no build-time token: ops users paste their admin JWT
# at /admin and the middleware validates it. Nothing to configure here.

# APN (Access Point Name) shown in the eSIM setup instructions. Defaults to
# "mobilitynet"; override only if the carrier requires a different APN.
NEXT_PUBLIC_APN_NAME=mobilitynet
